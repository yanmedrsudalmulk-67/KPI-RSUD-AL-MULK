# Dependencies
/node_modules
/.pnpm-store
/package-lock.json (if you prefer yarn or pnpm, but we keep it since we use npm)
# Wait, actually, let's keep package-lock.json tracked! It's better to track lockfiles in Git.

# Next.js Build Output
/.next/
/out/

# Production / Build Output
/build
/dist
/.serverless
/target

# TypeScript build info
tsconfig.tsbuildinfo

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Local Env and Secrets (CRITICAL for security, prevents leaking keys to GitHub)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Vercel and hosting-related
.vercel

# System files & OS specific
.DS_Store
Thumbs.db
*.pem
*.key
*.cert
*.pfx

# Firebase and other tooling logs
.firebase/
firestore-debug.log
ui-debug.log
firebase-debug.log
